generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ──────────── Enums ────────────

enum UserRole {
  USER
  MANAGER
  ADMIN
}

enum BusinessType {
  AGENCY
  FREELANCER
  BUSINESS
}

enum PostStatus {
  DRAFT
  IN_REVIEW
  APPROVED
  SCHEDULED
  PUBLISHED
  FAILED
}

enum TicketStatus {
  OPEN
  PENDING
  RESOLVED
  CLOSED
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  URGENT
}

enum Platform {
  INSTAGRAM
  FACEBOOK
  TWITTER
  YOUTUBE
  LINKEDIN
  TIKTOK
}

enum SubscriptionStatus {
  ACTIVE
  PAST_DUE
  CANCELED
  TRIALING
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum NotificationType {
  INFO
  WARNING
  SUCCESS
  ERROR
}

enum SentimentLabel {
  POSITIVE
  NEUTRAL
  NEGATIVE
}

enum JobStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
  RETRYING
}

// ──────────── Auth Models ────────────

model User {
  id              String    @id @default(cuid())
  name            String?
  email           String    @unique
  emailVerified   DateTime?
  hashedPassword  String?
  image           String?
  role            UserRole  @default(USER)
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  accounts        Account[]
  sessions        Session[]
  profile         Profile?
  workspaces      WorkspaceMember[]
  posts           Post[]
  supportTickets  SupportTicket[]
  supportMessages SupportMessage[]
  notifications   Notification[]
  auditLogs       AuditLog[]

  @@index([email])
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
  @@index([userId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ──────────── Profile & Workspace ────────────

model Profile {
  id           String        @id @default(cuid())
  userId       String        @unique
  businessType BusinessType?
  companyName  String?
  teamSize     String?
  platforms    String[]
  goals        String[]
  timezone     String        @default("UTC")
  onboarded    Boolean       @default(false)
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Workspace {
  id        String   @id @default(cuid())
  name      String
  slug      String   @unique
  logo      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  members           WorkspaceMember[]
  clients           Client[]
  socialConnections  SocialConnection[]
  posts             Post[]
  contentCategories ContentCategory[]
  reports           Report[]
  subscription      Subscription?
  settings          Settings?
  brandAssets       BrandAsset[]
  analyticsSnapshots AnalyticsSnapshot[]

  @@index([slug])
}

model WorkspaceMember {
  id          String   @id @default(cuid())
  userId      String
  workspaceId String
  role        UserRole @default(USER)
  joinedAt    DateTime @default(now())

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([userId, workspaceId])
  @@index([workspaceId])
}

// ──────────── Clients ────────────

model Client {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  email       String?
  phone       String?
  industry    String?
  timezone    String   @default("UTC")
  logo        String?
  notes       String?  @db.Text
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace         Workspace          @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  socialConnections SocialConnection[]
  posts             Post[]
  reports           Report[]
  brandAssets       BrandAsset[]

  @@index([workspaceId])
}

model BrandAsset {
  id          String   @id @default(cuid())
  clientId    String?
  workspaceId String
  name        String
  type        String
  url         String
  createdAt   DateTime @default(now())

  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([workspaceId])
}

// ──────────── Social Connections ────────────

model SocialConnection {
  id            String    @id @default(cuid())
  workspaceId   String
  clientId      String?
  platform      Platform
  accountName   String
  accountId     String?
  accessToken   String?   @db.Text
  refreshToken  String?   @db.Text
  tokenExpiry   DateTime?
  isConnected   Boolean   @default(true)
  lastSyncedAt  DateTime?
  errorMessage  String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)
  posts     Post[]

  @@index([workspaceId])
  @@index([clientId])
}

// ──────────── Content & Posts ────────────

model ContentCategory {
  id          String   @id @default(cuid())
  workspaceId String
  name        String
  color       String   @default("#6366f1")
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  posts     Post[]

  @@index([workspaceId])
}

model Post {
  id                 String     @id @default(cuid())
  workspaceId        String
  authorId           String
  clientId           String?
  socialConnectionId String?
  categoryId         String?
  platform           Platform
  caption            String     @db.Text
  hashtags           String[]
  status             PostStatus @default(DRAFT)
  createdAt          DateTime   @default(now())
  updatedAt          DateTime   @updatedAt

  workspace        Workspace         @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  author           User              @relation(fields: [authorId], references: [id])
  client           Client?           @relation(fields: [clientId], references: [id], onDelete: SetNull)
  socialConnection SocialConnection? @relation(fields: [socialConnectionId], references: [id], onDelete: SetNull)
  category         ContentCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  media            PostMedia[]
  schedule         PostSchedule?
  logs             PostLog[]

  @@index([workspaceId])
  @@index([authorId])
  @@index([status])
}

model PostMedia {
  id        String   @id @default(cuid())
  postId    String
  url       String
  type      String
  altText   String?
  order     Int      @default(0)
  createdAt DateTime @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
}

model PostSchedule {
  id          String    @id @default(cuid())
  postId      String    @unique
  scheduledAt DateTime
  publishedAt DateTime?
  timezone    String    @default("UTC")
  retryCount  Int       @default(0)
  maxRetries  Int       @default(3)
  jobId       String?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([scheduledAt])
}

model PostLog {
  id        String    @id @default(cuid())
  postId    String
  status    JobStatus
  message   String?   @db.Text
  metadata  Json?
  createdAt DateTime  @default(now())

  post Post @relation(fields: [postId], references: [id], onDelete: Cascade)

  @@index([postId])
  @@index([createdAt])
}

// ──────────── Analytics ────────────

model AnalyticsSnapshot {
  id          String   @id @default(cuid())
  workspaceId String
  platform    Platform
  date        DateTime
  followers   Int      @default(0)
  engagement  Float    @default(0)
  impressions Int      @default(0)
  reach       Int      @default(0)
  clicks      Int      @default(0)
  shares      Int      @default(0)
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)

  @@unique([workspaceId, platform, date])
  @@index([workspaceId])
  @@index([date])
}

model Report {
  id          String   @id @default(cuid())
  workspaceId String
  clientId    String?
  title       String
  dateFrom    DateTime
  dateTo      DateTime
  data        Json?
  createdAt   DateTime @default(now())

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  client    Client?   @relation(fields: [clientId], references: [id], onDelete: SetNull)

  @@index([workspaceId])
}

// ──────────── Billing ────────────

model Subscription {
  id               String             @id @default(cuid())
  workspaceId      String             @unique
  stripeCustomerId String?
  stripePriceId    String?
  stripeSubId      String?
  plan             String             @default("starter")
  status           SubscriptionStatus @default(TRIALING)
  currentPeriodEnd DateTime?
  cancelAtEnd      Boolean            @default(false)
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
  invoices  Invoice[]
  payments  Payment[]
}

model Invoice {
  id             String   @id @default(cuid())
  subscriptionId String
  stripeInvoiceId String?
  amount         Int
  currency       String   @default("usd")
  status         String
  pdfUrl         String?
  createdAt      DateTime @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
}

model Payment {
  id             String        @id @default(cuid())
  subscriptionId String
  stripePaymentId String?
  amount         Int
  currency       String        @default("usd")
  status         PaymentStatus @default(PENDING)
  createdAt      DateTime      @default(now())

  subscription Subscription @relation(fields: [subscriptionId], references: [id], onDelete: Cascade)

  @@index([subscriptionId])
}

// ──────────── Support ────────────

model SupportTicket {
  id        String         @id @default(cuid())
  userId    String
  subject   String
  status    TicketStatus   @default(OPEN)
  priority  TicketPriority @default(MEDIUM)
  createdAt DateTime       @default(now())
  updatedAt DateTime       @updatedAt

  user     User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@index([userId])
  @@index([status])
}

model SupportMessage {
  id        String   @id @default(cuid())
  ticketId  String
  userId    String
  content   String   @db.Text
  isAdmin   Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket SupportTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id])

  @@index([ticketId])
}

// ──────────── Notifications & Logs ────────────

model Notification {
  id        String           @id @default(cuid())
  userId    String
  title     String
  message   String
  type      NotificationType @default(INFO)
  read      Boolean          @default(false)
  link      String?
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([read])
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  action    String
  entity    String
  entityId  String?
  metadata  Json?
  ipAddress String?
  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@index([entity])
}

model ApiLog {
  id         String   @id @default(cuid())
  method     String
  path       String
  statusCode Int
  duration   Int
  userAgent  String?
  ipAddress  String?
  metadata   Json?
  createdAt  DateTime @default(now())

  @@index([createdAt])
  @@index([path])
}

model Settings {
  id          String   @id @default(cuid())
  workspaceId String   @unique
  branding    Json?
  preferences Json?
  apiKeys     Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  workspace Workspace @relation(fields: [workspaceId], references: [id], onDelete: Cascade)
}
